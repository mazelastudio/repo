# Cloudflare Pages — caching rules (this file is copied to the site root on build)

# Vite fingerprints these filenames, so they can be cached forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Artwork & video reels: cached a week, refreshed in the background after.
/gallery/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Security headers for the whole site
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
